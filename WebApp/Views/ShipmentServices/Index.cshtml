@model IEnumerable<Data.Models.ShipmentService>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Shipment)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Service)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Notes)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Shipment.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Service.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Notes)
            </td>
            <td>
                    <a asp-action="Details" asp-route-shipmentId="@item.ShipmentId" asp-route-serviceId="@item.ServiceId">Details</a>
                    <a asp-action="Edit" asp-route-shipmentId="@item.ShipmentId" asp-route-serviceId="@item.ServiceId">Edit</a>
                    <a asp-action="Delete" asp-route-shipmentId="@item.ShipmentId" asp-route-serviceId="@item.ServiceId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
